---
import { getCollection, getEntry, render } from "astro:content";
import Prose from "../../components/Prose.astro";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import RelatedPostsCompact from "../../components/RelatedPostsCompact.astro";
import { getReadingTime } from "../../utils/readingTime";

// Reading time configuration (words per minute)
const READING_TIME_CONFIG = {
  wordsPerMinute: 200,
  minReadingTime: 1,
};

export async function getStaticPaths() {
  const blogPosts = await getCollection("blog");
  return blogPosts.map((post) => {
    return {
      params: {
        postId: post.id,
      },
    };
  });
}

const { postId } = Astro.params;

const entry = await getEntry("blog", postId);
const { Content } = await render(entry);
const readingTime = getReadingTime(entry.body, READING_TIME_CONFIG);

// Get all blog posts for related posts section
const allPosts = await getCollection("blog");
---

<BlogPostLayout hasSidebar={true}>
  <fragment slot="content">
    <div class="mb-6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-theme-accent hover:text-theme-accent/80 transition-colors duration-200"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        <span>Back to Blog</span>
      </a>
    </div>
    <div
      id="post-top"
      class="flex flex-col gap-4 mb-8 border-b border-theme-border/30 pb-8"
    >
      <h1 class="text-5xl md:text-6xl font-bold text-theme-foreground">
        {entry.data.title}
      </h1>
      <h2 class="text-xl md:text-2xl text-theme-text/80">
        {entry?.data.description}
      </h2>
      <div
        class="flex flex-col md:flex-row md:justify-between gap-2 text-sm text-theme-text/60"
      >
        <p>{entry?.data.author}</p>
        <div class="flex gap-4">
          <p>{entry?.data.date}</p>
          <p class="text-theme-accent">{readingTime}</p>
        </div>
      </div>
    </div>
    <Prose>
      <Content />
    </Prose>

    <div class="mt-12 lg:hidden">
      <RelatedPostsCompact
        currentPostId={entry.id}
        currentTags={entry.data.tags || []}
        allPosts={allPosts}
        limit={3}
      />
    </div>
  </fragment>

  <fragment slot="sidebar">
    <div class="sidebar-content">
      <TableOfContents postTitle={entry.data.title} />
      <div class="hidden lg:block">
        <RelatedPostsCompact
          currentPostId={entry.id}
          currentTags={entry.data.tags || []}
          allPosts={allPosts}
          limit={3}
        />
      </div>
    </div>
  </fragment>
</BlogPostLayout>

<style>
  .sidebar-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .sidebar-content {
      padding-right: 0.5rem;
    }
  }
</style>
