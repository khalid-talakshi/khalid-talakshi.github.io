---
import { getCollection, render } from "astro:content";

import Prose from "../components/Prose.astro";
import StandardPageLayout from "../layouts/StandardPageLayout.astro";
import skillsData from "../data/skills.json";

// Get experience and education
const experience = (await getCollection("experience")).filter(
  (entry) => entry.data.hidden != true,
);
const education = (await getCollection("education")).filter(
  (entry) => entry.data.hidden != true,
);
const formalEducation = education
  .filter((entry) => entry.data.kind !== "certificate")
  .sort(
    (a, b) =>
      new Date(b.data.graduationDate ?? "").getTime() -
      new Date(a.data.graduationDate ?? "").getTime(),
  );
const certificatesAndCourses = education
  .filter((entry) => entry.data.kind === "certificate")
  .sort(
    (a, b) =>
      new Date(b.data.issueDate ?? "").getTime() -
      new Date(a.data.issueDate ?? "").getTime(),
  );
const experienceWithContent = await Promise.all(
  experience.map(async (entry) => {
    const { Content } = await render(entry);
    return { ...entry, Content };
  }),
);
const formalEducationWithContent = await Promise.all(
  formalEducation.map(async (entry) => {
    const { Content } = await render(entry);
    return { ...entry, Content };
  }),
);
const certificatesWithContent = await Promise.all(
  certificatesAndCourses.map(async (entry) => {
    const { Content } = await render(entry);
    return { ...entry, Content };
  }),
);

// Format date helper
const formatDate = (dateStr: string): string => {
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
};

// Calculate duration
const calculateDuration = (start: string, end?: string): string => {
  const startDate = new Date(start);
  const endDate = end ? new Date(end) : new Date();
  const months =
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
    (endDate.getMonth() - startDate.getMonth());
  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;

  if (years > 0 && remainingMonths > 0) {
    return `${years}y ${remainingMonths}m`;
  } else if (years > 0) {
    return `${years}y`;
  } else {
    return `${remainingMonths}m`;
  }
};

const formatDateRange = (start: string, end?: string): string => {
  return `${formatDate(start)} - ${end ? formatDate(end) : "Present"}`;
};

const SKILLS_PREVIEW_COUNT = 6;

const getVisibleSkills = (skills: readonly string[]): readonly string[] => {
  return skills.slice(0, SKILLS_PREVIEW_COUNT);
};

const getOverflowSkills = (skills: readonly string[]): readonly string[] => {
  return skills.slice(SKILLS_PREVIEW_COUNT);
};
---

<StandardPageLayout>
  {/* Page Header */}
  <section class="py-8 md:py-12 border-b border-theme-border/20">
    <h1 class="text-4xl md:text-5xl font-bold text-theme-primary mb-4">
      About Me
    </h1>
    <p class="text-lg text-theme-text/80 max-w-2xl">
      Full-stack developer, designer, and creative technologist passionate about
      building beautiful, functional digital experiences.
    </p>
  </section>

  {/* Bio Section */}
  <section class="py-12 md:py-16">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold text-theme-primary mb-6">Who I Am</h2>
      <div class="space-y-4 text-theme-text/80 leading-relaxed">
        <p>
          I’m a full-stack developer who likes thinking in systems. I love
          building things end-to-end, especially when the problem is messy and
          needs both good architecture and practical execution.
        </p>

        <p>
          A lot of my work and interests live at the intersection of sports,
          analytics, and game design. I’m especially into baseball, F1, and
          soccer, and I enjoy working on projects where data can actually
          improve decisions and performance. I pick things up quickly, I’m happy
          to jump into whatever needs to get done, and I like helping teams move
          forward when things get complex.
        </p>

        <p>
          Outside of work, I’m usually thinking about game design, playing
          hockey, writing D&D campaigns, or posting about movies and sports. I’m
          always open to new opportunities in sports where I can build useful
          systems and work on meaningful problems.
        </p>
      </div>
    </div>
  </section>

  {/* Experience Section */}
  {
    experience.length > 0 && (
      <section class="py-12 md:py-16 border-t border-theme-border/20">
        <h2 class="text-3xl font-bold text-theme-primary mb-8">Experience</h2>
        <div class="space-y-6">
          {experienceWithContent.map((exp) => {
            const ExperienceContent = exp.Content;

            return (
              <div class="relative pl-8 pb-6 border-l-2 border-theme-primary/30 last:pb-0">
                {/* Timeline dot */}
                <div class="absolute -left-3 top-0 w-4 h-4 rounded-full bg-theme-primary border-4 border-theme-background" />

                {/* Content */}
                <div>
                  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-2">
                    <div>
                      <h3 class="text-xl font-bold text-theme-accent">
                        {exp.data.role}
                      </h3>
                      <p class="text-theme-text/70">{exp.data.company}</p>
                    </div>
                    <div class="text-sm text-theme-text/60 whitespace-nowrap">
                      {formatDateRange(exp.data.startDate, exp.data.endDate)}
                      <span class="ml-2 text-theme-primary">
                        (
                        {calculateDuration(
                          exp.data.startDate,
                          exp.data.endDate,
                        )}
                        )
                      </span>
                    </div>
                  </div>

                  <div class="mb-3">
                    <Prose>
                      <ExperienceContent />
                    </Prose>
                  </div>

                  {exp.data.technologies &&
                    exp.data.technologies.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {exp.data.technologies.map((tech: string) => (
                          <span class="inline-block px-3 py-1 rounded-full bg-theme-primary/20 text-xs font-medium text-theme-primary">
                            {tech}
                          </span>
                        ))}
                      </div>
                    )}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Education Section */}
  {
    (formalEducation.length > 0 || certificatesAndCourses.length > 0) && (
      <section class="py-12 md:py-16 border-t border-theme-border/20">
        <h2 class="text-3xl font-bold text-theme-primary mb-8">Education</h2>
        <div class="space-y-10">
          {formalEducationWithContent.length > 0 && (
            <div>
              <h3 class="text-lg md:text-xl font-semibold text-theme-accent mb-5">
                Formal Education
              </h3>
              <div class="space-y-6">
                {formalEducationWithContent.map((edu) => {
                  const EducationContent = edu.Content;

                  return (
                    <div class="relative pl-8 pb-6 border-l-2 border-theme-accent/30 last:pb-0">
                      {/* Timeline dot */}
                      <div class="absolute -left-3 top-0 w-4 h-4 rounded-full bg-theme-accent border-4 border-theme-background" />

                      {/* Content */}
                      <div>
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-2">
                          <div>
                            <h4 class="text-xl font-bold text-theme-accent">
                              {edu.data.degree}
                            </h4>
                            <p class="text-theme-text/70">{edu.data.school}</p>
                            <p class="text-sm text-theme-text/60">
                              {edu.data.field}
                            </p>
                          </div>
                          <div class="text-sm text-theme-text/60 whitespace-nowrap">
                            {edu.data.graduationDate
                              ? formatDate(edu.data.graduationDate)
                              : ""}
                          </div>
                        </div>

                        <Prose>
                          <EducationContent />
                        </Prose>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {certificatesWithContent.length > 0 && (
            <div class="pt-8 border-t border-theme-border/20">
              <h3 class="text-lg md:text-xl font-semibold text-theme-primary mb-5">
                Certificates & Courses
              </h3>
              <div class="space-y-4">
                {certificatesWithContent.map((certificate) => {
                  const CertificateContent = certificate.Content;

                  return (
                    <article class="rounded-xl border border-theme-border/30 bg-gradient-to-br from-theme-primary/5 to-theme-accent/5 p-5">
                      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-1">
                        <h4 class="text-lg font-bold text-theme-primary">
                          {certificate.data.title}
                        </h4>
                        <span class="text-sm text-theme-text/60 whitespace-nowrap">
                          {certificate.data.issueDate
                            ? formatDate(certificate.data.issueDate)
                            : ""}
                        </span>
                      </div>

                      <p class="text-theme-text/70 mb-2">
                        {certificate.data.issuer}
                      </p>

                      <Prose>
                        <CertificateContent />
                      </Prose>

                      {(certificate.data.credentialId ||
                        certificate.data.credentialUrl) && (
                        <div class="flex flex-wrap items-center gap-3 text-sm text-theme-text/60 mt-3">
                          {certificate.data.credentialId && (
                            <span>
                              Credential ID: {certificate.data.credentialId}
                            </span>
                          )}
                          {certificate.data.credentialUrl && (
                            <a
                              href={certificate.data.credentialUrl}
                              target="_blank"
                              rel="noreferrer"
                              class="text-theme-accent hover:text-theme-accent/80 transition-colors"
                            >
                              View Credential
                            </a>
                          )}
                        </div>
                      )}
                    </article>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </section>
    )
  }

  {/* Skills Section */}
  <section class="py-12 md:py-16 border-t border-theme-border/20">
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-theme-primary">Skills</h2>
      <p class="text-theme-text/70 mt-2">
        Core tools and technologies I use most often.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        skillsData.skills.map((skillGroup) => {
          const visibleSkills = getVisibleSkills(skillGroup.items);
          const overflowSkills = getOverflowSkills(skillGroup.items);

          return (
            <article class="rounded-xl border border-theme-border/30 bg-gradient-to-br from-theme-primary/5 to-theme-accent/5 p-6">
              <div class="flex items-center justify-between gap-3 mb-4">
                <h3 class="text-xl md:text-2xl font-bold text-theme-primary">
                  {skillGroup.category}
                </h3>
                <span class="inline-flex items-center rounded-full border border-theme-border/30 px-2.5 py-1 text-sm font-medium text-theme-text/70">
                  {skillGroup.items.length}
                </span>
              </div>

              <div class="flex flex-wrap gap-2">
                {visibleSkills.map((skill: string) => (
                  <span class="inline-flex items-center px-3 py-1 rounded-full bg-theme-primary/20 text-sm font-medium text-theme-primary">
                    {skill}
                  </span>
                ))}
              </div>

              {overflowSkills.length > 0 && (
                <details class="mt-4 group">
                  <summary class="cursor-pointer list-none inline-flex items-center gap-2 text-base text-theme-accent hover:text-theme-accent/80 transition-colors">
                    <span>+ {overflowSkills.length} more</span>
                    <span class="text-sm group-open:hidden">Show</span>
                    <span class="text-sm hidden group-open:inline">Hide</span>
                  </summary>

                  <div class="mt-3 flex flex-wrap gap-2">
                    {overflowSkills.map((skill: string) => (
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-theme-background/60 border border-theme-border/30 text-sm font-medium text-theme-text/80">
                        {skill}
                      </span>
                    ))}
                  </div>
                </details>
              )}
            </article>
          );
        })
      }
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-12 md:py-16 border-t border-theme-border/20">
    <div
      class="rounded-2xl border border-theme-border/30 bg-gradient-to-r from-theme-primary/10 to-theme-accent/10 p-8 md:p-12 text-center"
    >
      <h2 class="text-3xl font-bold text-theme-primary mb-4">
        Let's Work Together
      </h2>
      <p class="text-lg text-theme-text/80 mb-8 max-w-2xl mx-auto">
        I'm always interested in hearing about new projects and opportunities.
        Feel free to reach out if you'd like to collaborate!
      </p>
      <a
        href="mailto:hello@khalidtalakshi.com"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-theme-primary to-theme-accent hover:shadow-lg hover:shadow-theme-primary/30 transition-all duration-300 hover:scale-105"
      >
        Get In Touch
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
      </a>
    </div>
  </section>
</StandardPageLayout>
