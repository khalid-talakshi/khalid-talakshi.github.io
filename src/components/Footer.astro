---
// Footer component - Minimal footer with links and copyright

export interface Props {
  year?: number;
}

const { year = new Date().getFullYear() } = Astro.props;

const socialLinks = [
  { text: "GitHub", href: "https://github.com", icon: "github" },
  { text: "LinkedIn", href: "https://linkedin.com", icon: "linkedin" },
  { text: "Twitter", href: "https://twitter.com", icon: "twitter" },
];

const footerLinks = [
  { text: "Home", href: "/" },
  { text: "About", href: "/about" },
  { text: "Projects", href: "/projects" },
  { text: "Blog", href: "/blog" },
];
---

<footer
  class="w-full border-t border-theme-border/30 bg-theme-background/50 backdrop-blur-sm mt-12 md:mt-16"
>
  <div class="w-full sm:w-[95%] mx-auto px-4 sm:px-0 py-8 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {/* Brand Section */}
      <div class="flex flex-col gap-3">
        <h3
          class="text-lg font-bold bg-gradient-to-r from-theme-foreground to-theme-accent bg-clip-text text-transparent"
        >
          Khalid Talakshi
        </h3>
        <p class="text-sm text-theme-text/70 leading-relaxed">
          Full-stack developer, designer, and creative technologist.
        </p>
      </div>

      {/* Navigation Links */}
      <div class="flex flex-col gap-3">
        <h4
          class="font-semibold text-theme-primary text-sm uppercase tracking-wide"
        >
          Navigation
        </h4>
        <ul class="flex flex-col gap-2">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-theme-text/70 hover:text-theme-accent transition-colors duration-200"
                >
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Social Links */}
      <div class="flex flex-col gap-3">
        <h4
          class="font-semibold text-theme-primary text-sm uppercase tracking-wide"
        >
          Connect
        </h4>
        <ul class="flex items-center gap-3">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-theme-border/30 text-theme-text/70 hover:text-theme-accent hover:bg-theme-accent/10 hover:border-theme-accent/40 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-primary focus-visible:ring-offset-2 focus-visible:ring-offset-theme-background"
                  aria-label={`${link.text} (opens in new tab)`}
                >
                  {link.icon === "github" && (
                    <svg
                      class="h-5 w-5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M12 0C5.37 0 0 5.37 0 12a12 12 0 008.21 11.39c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.41-4.04-1.41-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.67-.31-5.47-1.34-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.56.12-3.26 0 0 1.01-.32 3.3 1.23A11.44 11.44 0 0112 5.8c1.02 0 2.05.14 3.01.41 2.29-1.55 3.3-1.23 3.3-1.23.66 1.7.24 2.95.12 3.26.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.82 1.1.82 2.23v3.31c0 .32.22.69.82.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                  )}

                  {link.icon === "linkedin" && (
                    <svg
                      class="h-5 w-5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.68H9.32V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.61 0 4.28 2.37 4.28 5.45v6.3zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z" />
                    </svg>
                  )}

                  {link.icon === "twitter" && (
                    <svg
                      class="h-5 w-5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M18.244 2H21.5l-7.11 8.13L22.75 22h-6.54l-5.12-6.7L5.24 22H2l7.6-8.7L1.5 2h6.7l4.63 6.12L18.244 2zm-1.14 18h1.8L7.22 3.9H5.3L17.104 20z" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {/* Copyright */}
    <div
      class="border-t border-theme-border/20 mt-8 pt-6 text-center text-xs text-theme-text/50"
    >
      <p>
        &copy; {year} Khalid Talakshi. All rights reserved. Built with Astro.
      </p>
    </div>
  </div>
</footer>
