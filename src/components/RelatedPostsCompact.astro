---
// RelatedPostsCompact component - Compact version of related posts
// Shows up to 3 related posts with minimal footprint

import type { CollectionEntry } from "astro:content";

export interface Props {
  currentPostId: string;
  currentTags: string[];
  allPosts: CollectionEntry<"blog">[];
  limit?: number;
}

const { currentPostId, currentTags, allPosts, limit = 3 } = Astro.props;

// Filter and score related posts
const relatedPosts = allPosts
  .filter((post) => post.id !== currentPostId && post.data.published)
  .map((post) => {
    // Calculate relevance score based on shared tags
    const sharedTags = (post.data.tags || []).filter((tag) =>
      currentTags.includes(tag),
    );
    return {
      post,
      score: sharedTags.length,
    };
  })
  .filter((item) => item.score > 0) // Only include posts with at least one shared tag
  .sort((a, b) => {
    // Sort by score (descending), then by date (newest first)
    if (b.score !== a.score) {
      return b.score - a.score;
    }
    return (
      new Date(b.post.data.date).getTime() -
      new Date(a.post.data.date).getTime()
    );
  })
  .slice(0, limit)
  .map((item) => item.post);

// Format date helper
const formatDate = (dateStr: string): string => {
  try {
    const [day, month, year] = dateStr.split("-");
    const dateObj = new Date(`${year}-${month}-${day}`);
    return dateObj.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
};
---

{
  relatedPosts.length > 0 && (
    <section class="related-posts-compact-section">
      <div class="related-posts-compact-header">
        <h3 class="related-posts-compact-title">Related Posts</h3>
      </div>

      <div class="related-posts-compact-list">
        {relatedPosts.map((post) => (
          <a href={`/posts/${post.id}`} class="related-post-item">
            <div class="related-post-content">
              <h4 class="related-post-title">{post.data.title}</h4>
              <div class="related-post-meta">
                <span class="related-post-date">
                  {formatDate(post.data.date)}
                </span>
                <span class="related-post-reading-time">
                  {Math.ceil(post.body.split(/\s+/).length / 200)} min
                </span>
              </div>
            </div>
            <svg
              class="related-post-arrow"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  /* Desktop sidebar layout */
  @media (min-width: 1024px) {
    .related-posts-compact-section {
      border-top: 1px solid var(--color-theme-border);
      border-top-opacity: 0.3;
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
      margin-top: 1.5rem;
    }

    .related-posts-compact-header {
      margin-bottom: 1.25rem;
    }

    .related-posts-compact-title {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-theme-accent);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .related-posts-compact-title::before {
      content: "";
      display: inline-block;
      width: 3px;
      height: 1rem;
      background-color: var(--color-theme-accent);
      border-radius: 2px;
    }

    .related-posts-compact-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .related-post-item {
      display: flex;
      flex-direction: column;
      padding: 0.875rem;
      border-radius: 0.5rem;
      border: 1px solid var(--color-theme-border);
      border-opacity: 0.2;
      background-color: color-mix(
        in oklab,
        var(--color-theme-accent) 3%,
        transparent
      );
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: inherit;
    }

    .related-post-item:hover {
      border-color: var(--color-theme-accent);
      border-opacity: 0.4;
      background-color: color-mix(
        in oklab,
        var(--color-theme-accent) 8%,
        transparent
      );
      transform: translateX(4px);
    }

    .related-post-content {
      flex: 1;
      min-width: 0;
    }

    .related-post-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-theme-foreground);
      margin-bottom: 0.375rem;
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .related-post-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.7rem;
      color: color-mix(in oklab, var(--color-theme-text) 60%, transparent);
    }

    .related-post-date {
      white-space: nowrap;
    }

    .related-post-reading-time {
      color: var(--color-theme-accent);
      font-weight: 500;
    }

    .related-post-arrow {
      display: none;
    }
  }

  /* Mobile layout */
  @media (max-width: 1023px) {
    .related-posts-compact-section {
      border-top: 1px solid var(--color-theme-border);
      border-top-opacity: 0.2;
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
      margin-top: 1.5rem;
    }

    .related-posts-compact-header {
      margin-bottom: 1rem;
    }

    .related-posts-compact-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--color-theme-foreground);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .related-posts-compact-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    @media (min-width: 640px) {
      .related-posts-compact-list {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }
    }

    .related-post-item {
      display: flex;
      flex-direction: column;
      padding: 0.875rem;
      border-radius: 0.5rem;
      border: 1px solid var(--color-theme-border);
      border-opacity: 0.2;
      background-color: color-mix(
        in oklab,
        var(--color-theme-accent) 2%,
        transparent
      );
      transition: all 0.2s;
      text-decoration: none;
      color: inherit;
    }

    .related-post-item:active {
      border-color: var(--color-theme-accent);
      border-opacity: 0.4;
      background-color: color-mix(
        in oklab,
        var(--color-theme-accent) 8%,
        transparent
      );
    }

    .related-post-content {
      flex: 1;
      min-width: 0;
    }

    .related-post-title {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-theme-foreground);
      margin-bottom: 0.375rem;
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .related-post-meta {
      display: flex;
      gap: 0.5rem;
      font-size: 0.7rem;
      color: color-mix(in oklab, var(--color-theme-text) 60%, transparent);
    }

    .related-post-date {
      white-space: nowrap;
    }

    .related-post-reading-time {
      color: var(--color-theme-accent);
      font-weight: 500;
    }

    .related-post-arrow {
      display: none;
    }
  }
</style>
